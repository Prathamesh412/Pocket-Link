<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error - Web Links</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-slate-900 font-sans">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md bg-white rounded-lg shadow-lg p-6 text-center">
      <div class="text-6xl mb-4">❌</div>
      <h1 class="text-2xl font-bold mb-2">Error</h1>
      <p class="text-slate-600 mb-6"><%= error %></p>
      <button onclick="window.close()" class="bg-blue-600 text-white px-4 py-2 rounded font-medium hover:bg-blue-700 transition-colors">
        Close
      </button>
    </div>
  </div>
</body>
</html>
